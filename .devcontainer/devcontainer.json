{
  "name": "Python DevContainer",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "workspaceFolder": "/workspace",

  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy"
      ]
    }
  },

  "postCreateCommand": "pip install -r requirements.txt"
}
